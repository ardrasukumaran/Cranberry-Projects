# ─────────────────────────────────────────────────────────────
# Migraine Tracker – environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Webhook URL for forwarding attack logs to a spreadsheet.
# Every time a user logs an attack the app POSTs this JSON payload:
#
#   {
#     "phone":     "+11234567890",
#     "date":      "2025-05-14",
#     "intensity": 7,
#     "status":    "Done",
#     "duration":  "3–6h",
#     "foods":     "Red wine, Coffee",
#     "loggedAt":  "2025-05-14T18:30:00.000Z"
#   }
#
# ── Option A: Google Sheets via Apps Script (free, recommended) ──
#
#  1. Open your Google Sheet.
#  2. Extensions → Apps Script → paste the code below → Save.
#  3. Deploy → New deployment → Web app
#       Execute as: Me  |  Who has access: Anyone
#  4. Copy the deployment URL and paste it below.
#
#  ┌─ Apps Script code ──────────────────────────────────────────
#  │
#  │  function doPost(e) {
#  │    const data = JSON.parse(e.postData.contents);
#  │    const sheet = SpreadsheetApp.getActiveSpreadsheet()
#  │                    .getSheetByName("Attacks") ||
#  │                  SpreadsheetApp.getActiveSpreadsheet()
#  │                    .insertSheet("Attacks");
#  │
#  │    if (sheet.getLastRow() === 0) {
#  │      sheet.appendRow([
#  │        "Phone","Date","Intensity","Status","Duration","Foods","Logged At"
#  │      ]);
#  │    }
#  │
#  │    sheet.appendRow([
#  │      data.phone, data.date, data.intensity,
#  │      data.status, data.duration, data.foods, data.loggedAt
#  │    ]);
#  │
#  │    return ContentService
#  │      .createTextOutput(JSON.stringify({ ok: true }))
#  │      .setMimeType(ContentService.MimeType.JSON);
#  │  }
#  │
#  └─────────────────────────────────────────────────────────────
#
# ── Option B: Make.com / Zapier webhook ──
#
#  Create a new webhook trigger in Make.com or Zapier, then add a
#  Google Sheets "Add Row" action. Paste the webhook URL below.
#
VITE_WEBHOOK_URL=
